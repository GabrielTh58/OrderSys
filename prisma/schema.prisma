generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "sqlite"
}

model OrderItem {
  id        String      @id @default(uuid())
  quantity  Int
  price     Float
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
}

model User {
  id            String      @id @default(uuid())
  name          String
  email         String      @unique
  password      String
  createdAt     DateTime    @default(now())
  orders        Order[]
}

model Order {
  id            String      @id @default(uuid())
  orderItems    OrderItem[]
  total         Float
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  createdAt     DateTime    @default(now())
}

model Products {
  id            String      @id @default(uuid())
  name          String
  price         Float
  stock         Int
  createdAt     DateTime    @default(now())
}