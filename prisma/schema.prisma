generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String      @id @default(uuid())
  name          String
  email         String      @unique
  password      String
  createdAt     DateTime    @default(now())
}

model Order {
  id            String      @id @default(uuid())
  productId     String
  orderid       String
  quantity      Int
  price         Float
  createdAt     DateTime    @default(now())
}

model Products {
  id            String      @id @default(uuid())
  name          String
  price         Float
  stock         Int
  createdAt     DateTime    @default(now())
}